{
  "name": "@palserver/agent",
  "version": "2.6.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "palserver-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "gen:boss-lua": "node scripts/gen-boss-lua.mjs",
    "gen:boss-catalog": "node scripts/gen-boss-catalog.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.0.0",
    "@kubernetes/client-node": "^1.3.0",
    "@palserver/discord-bot": "workspace:*",
    "@palserver/shared": "workspace:*",
    "dockerode": "^4.0.2",
    "extract-zip": "^2.0.1",
    "fastify": "^5.2.0",
    "pidusage": "^4.0.1",
    "selfsigned": "^5.5.0",
    "stream-json": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^22.0.0",
    "@types/pidusage": "^2.0.5",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }

{
  "name": "@palserver/stats",
  "version": "2.0.0-alpha.0",
  "private": true,
  "description": "Anonymous usage stats collector (Cloudflare Worker + D1) for palserver GUI.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute palserver-stats --remote --file=schema.sql",
    "license:test": "node manage.mjs test-webhook",
    "license:issue": "node manage.mjs issue",
    "license:reset": "node manage.mjs reset"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.0",
    "typescript": "^5.7.2",
    "wrangler": "^4.24.0"
  }
}

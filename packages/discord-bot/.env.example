# ── 唯一必填 ──────────────────────────────────────────────────────────
# Discord bot token。到 Discord Developer Portal(discord.com/developers/applications)
# 建立 Application → 「Bot」分頁 Reset Token 取得。
# (Application ID / 伺服器 ID 都不用填 —— bot 啟動時會自動把指令註冊到它所在的每個伺服器。)
DISCORD_TOKEN=

# ── 以下全部選填 ──────────────────────────────────────────────────────
# agent 的 REST API 位置(不需結尾斜線)。bot 與 agent 同機時「不用設」,用預設本機即可;
# 分開部署才改成 agent 主機位址(例如 Tailscale 內網位址)。
# AGENT_URL=http://127.0.0.1:8250

# 只有「跨機」才需要:bot 與 agent 同機、連 127.0.0.1 時,agent 對本機免 token。
# 跨機時的取得方式:GUI 的「Discord Bot」分頁直接複製,或 agent 主機 data-dir 的 token 檔。
# AGENT_TOKEN=

# 固定操作某一個實例(agent 可能同時管多台)。留空 = 自動取第一個(單台伺服器不用設)。
# AGENT_INSTANCE_ID=

# embed 左上角品牌小圖示的公開網址。留空則不顯示。
# BRAND_ICON_URL=
